<Page
    x:Class="Tests_and_Interviews.Views.RecruiterPage"
    x:Name="ThisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Tests_and_Interviews.Models"
    xmlns:viewmodels="using:Tests_and_Interviews.ViewModels"
    xmlns:converters="using:Tests_and_Interviews.Helpers"
    Background="#C9BEFF">

    <Page.Resources>
        <converters:IdToColorConverter x:Key="StatusToColorConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <viewmodels:RecruiterViewModel />
    </Page.DataContext>

    <Grid Padding="60">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

  
        <StackPanel Grid.Column="0" Spacing="20">
            <TextBlock Text="Calendar Recrutor"
                       FontSize="35"
                       FontWeight="Bold"
                       Foreground="#6366FF"/>

            <CalendarView x:Name="MainCalendar"
                          SelectionMode="Single"
                          SelectedDatesChanged="MainCalendar_SelectedDatesChanged"
                          Foreground="#6366FF"/>
        </StackPanel>


        <Grid Grid.Column="1" Margin="80,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding SelectedDateFormatted}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <ListView Grid.Row="1"
                      ItemsSource="{Binding Slots}"
                      SelectionMode="None"
                      BorderThickness="0"
                      HorizontalContentAlignment="Stretch">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,8"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Slot">

                        <Grid Height="70">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding FormattedTime}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>


                            <Border Grid.Column="1"
                                Height="50"
                                Margin="5,0"
                                Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                BorderThickness="1"
                                BorderBrush="#6366FF"
                                CornerRadius="10">

                                <Button Background="Transparent"
                                    Command="{Binding DataContext.CreateSlotCommand, ElementName=ThisPage}"
                                    CommandParameter="{Binding}">

                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <TextBlock Text="{Binding TimeRange}"
                                                    Foreground="White"
                                                    FontWeight="Bold"/>

                                        <TextBlock Text="{Binding InterviewType}"
                                                                Foreground="White"
                                                   Visibility="{Binding InterviewType, Converter={StaticResource StringToVisibilityConverter}}"/>

                                    </StackPanel>
                                </Button>

                            </Border>

                        </Grid>

                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Grid>
    </Grid>
</Page>