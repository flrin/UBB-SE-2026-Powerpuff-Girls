<Page
    x:Class="Tests_and_Interviews.Views.CandidateHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">

        <StackPanel Spacing="16">

            <TextBlock Text="Welcome back!"
                       FontSize="28"
                       FontWeight="Bold"/>

            <TextBlock Text="Companies matched with you"
                       FontSize="18"
                       Foreground="Gray"/>

            <ListView ItemsSource="{Binding MatchedCompanies}">
                <ListView.ItemTemplate>
                    <DataTemplate>

                        <Border CornerRadius="12"
                                Padding="16"
                                Margin="0,8"
                                Background="#F5F5F5">

                            <StackPanel Spacing="8">

                                <TextBlock Text="{Binding CompanyName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding JobTitle}"
                                           FontSize="14"
                                           Foreground="Gray"/>

                                <Button Content="Schedule Interview"
                                        HorizontalAlignment="Right"
                                        Command="{Binding ScheduleCommand}"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>

    </Grid>
</Page>